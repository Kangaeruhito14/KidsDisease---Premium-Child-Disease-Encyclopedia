---
import Seo from '../components/Seo.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
    title: string;
    description: string;
    ogType?: 'website' | 'article';
    image?: string;
    jsonLd?: object[];
    keywords?: string[];
}

const { title, description, ogType, image, jsonLd = [], keywords = [] } = Astro.props;

// Google Analytics (GA4). Defined here as strings so the inline init script can
// be injected via set:html without the JSX parser mistaking its braces for
// expressions. Only emitted in the production build (see below).
const GA_ID = 'G-ZZW979TXFQ';
const GA_SRC = `https://www.googletagmanager.com/gtag/js?id=${GA_ID}`;
const GA_INIT = `window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${GA_ID}');`;

// Site-wide organization + website entities, merged with page-level JSON-LD.
const siteUrl = Astro.site?.toString();
const siteJsonLd = [
    {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'Kids Disease',
        alternateName: ['KidsDisease', 'Kids Disease Encyclopedia', 'Child Disease Encyclopedia'],
        url: siteUrl,
        inLanguage: 'en',
        description:
            'Educational child disease encyclopedia for parents and caregivers. Not a substitute for professional medical advice.',
        publisher: { '@id': `${siteUrl}#org` }
    },
    {
        '@context': 'https://schema.org',
        '@type': 'Organization',
        '@id': `${siteUrl}#org`,
        name: 'Kids Disease',
        url: siteUrl,
        logo: `${siteUrl}favicon.svg`,
        description:
            'A free, source-cited educational encyclopedia of childhood diseases for parents and caregivers.',
        sameAs: ['https://github.com/Kangaeruhito14/KidsDisease---Premium-Child-Disease-Encyclopedia']
    },
    ...jsonLd
];
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <!-- Google Analytics (GA4). Loaded only in the production build so that
             local `npm run dev` traffic never pollutes the analytics data. -->
        {
            import.meta.env.PROD && (
                <Fragment>
                    <script is:inline async src={GA_SRC} />
                    <script is:inline set:html={GA_INIT} />
                </Fragment>
            )
        }
        <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="shortcut icon" href="/favicon.ico" />
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
        <meta name="apple-mobile-web-app-title" content="KidsDisease" />
        <link rel="manifest" href="/site.webmanifest" />
        <meta name="theme-color" content="#2ABFBF" />
        <meta name="generator" content={Astro.generator} />
        <Seo {title} {description} {ogType} {image} {keywords} jsonLd={siteJsonLd} />

        <!-- Set theme before first paint to avoid a light-mode flash -->
        <script is:inline>
            (function () {
                try {
                    var stored = localStorage.getItem('kidsdisease-theme');
                    var dark = stored
                        ? stored === 'dark'
                        : window.matchMedia('(prefers-color-scheme: dark)').matches;
                    if (dark) document.documentElement.classList.add('dark');
                } catch (e) {
                    /* storage unavailable: stay light */
                }
            })();
        </script>

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,900&family=Outfit:wght@300;400;500;600;700;800;900&display=swap"
            rel="stylesheet"
        />
        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
            integrity="sha384-iw3OoTErCYJJB9mCa8LNS2hbsQ7M3C0EpIsO/H5+EGAkPGc6rk+V8i04oW/K5xq0"
            crossorigin="anonymous"
        />
    </head>
    <body class="min-h-screen flex flex-col font-sans antialiased">
        <a href="#main-content" class="skip-link">Skip to main content</a>
        <Header />
        <main id="main-content" class="flex-1 w-full pb-20 md:pb-0">
            <slot />
        </main>
        <Footer />
    </body>
</html>
