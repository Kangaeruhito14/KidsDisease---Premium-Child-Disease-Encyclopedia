---
/**
 * Visible breadcrumb trail + BreadcrumbList structured data.
 * The last item is the current page (not a link).
 */
interface Crumb {
    name: string;
    href?: string;
}

interface Props {
    items: Crumb[];
}

const { items } = Astro.props;

const jsonLd = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: items.map((c, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: c.name,
        ...(c.href ? { item: new URL(c.href, Astro.site).toString() } : {})
    }))
};
---

<nav
    aria-label="Breadcrumb"
    class="px-4 md:px-8 py-3 bg-white dark:bg-night-card border-b border-orange-100/50 dark:border-night-line text-xs flex items-center flex-wrap gap-1.5 text-slate-600 dark:text-[#B1A9DE]"
>
    <ol class="flex items-center flex-wrap gap-1.5 list-none">
        {
            items.map((c, i) => (
                <li class="flex items-center gap-1.5">
                    {i > 0 && <i class="fa-solid fa-chevron-right text-[9px] text-slate-400" aria-hidden="true" />}
                    {c.href ? (
                        <a href={c.href} class="hover:text-brand-teal font-bold transition-colors">
                            {c.name}
                        </a>
                    ) : (
                        <span class="text-slate-800 dark:text-[#F1EDFF] font-extrabold" aria-current="page">
                            {c.name}
                        </span>
                    )}
                </li>
            ))
        }
    </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
