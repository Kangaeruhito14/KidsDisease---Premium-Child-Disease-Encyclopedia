---
const links = [
    { href: '/', label: 'Home', icon: 'fa-house' },
    { href: '/systems/', label: 'Body Systems', icon: 'fa-cubes' },
    { href: '/diseases/', label: 'Diseases A–Z', icon: 'fa-book-medical' },
    { href: '/vaccines/', label: 'Vaccines', icon: 'fa-syringe' },
    { href: '/triage/', label: 'Triage', icon: 'fa-heart-circle-exclamation' },
    { href: '/search/', label: 'Search', icon: 'fa-magnifying-glass' }
];

const path = Astro.url.pathname;
const isActive = (href: string) =>
    href === '/' ? path === '/' : path.startsWith(href);
---

<header
    class="sticky top-0 z-50 bg-white/95 dark:bg-night-card/95 border-b border-orange-200/50 dark:border-night-line shadow-premium backdrop-blur-md"
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 select-none" aria-label="Kids Disease home">
            <span class="w-10 h-10 rounded-2xl bg-gradient-to-br from-brand-teal to-brand-teal-soft flex items-center justify-center shadow-md shadow-brand-teal/30">
                <svg viewBox="0 0 64 64" class="w-6 h-6" aria-hidden="true">
                    <path fill="#FFFFFF" d="M32 47C20 38 14 31 14 25c0-5 4-8 9-8 4 0 7 2 9 5 2-3 5-5 9-5 5 0 9 3 9 8 0 6-6 13-18 22Z" />
                    <path fill="none" stroke="#2ABFBF" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" d="M18 30h6l3-6 4 12 3-6h7" />
                </svg>
            </span>
            <span>
                <span class="block font-black text-xl text-slate-800 dark:text-[#F1EDFF] tracking-tight leading-none">Kids Disease</span>
                <span class="block text-[9px] font-black text-slate-600 dark:text-[#B1A9DE] uppercase tracking-wider mt-0.5">
                    Child Disease Encyclopedia
                </span>
            </span>
        </a>

        <nav class="hidden md:flex items-center gap-1" aria-label="Primary">
            {
                links.map(l => (
                    <a
                        href={l.href}
                        aria-current={isActive(l.href) ? 'page' : undefined}
                        class:list={[
                            'px-3 py-2 rounded-xl text-xs font-black transition-colors flex items-center gap-1.5',
                            isActive(l.href)
                                ? 'bg-teal-50 text-brand-teal dark:bg-night-line dark:text-brand-teal-soft'
                                : 'text-slate-700 hover:bg-slate-50 dark:text-[#B1A9DE] dark:hover:bg-night-line dark:hover:text-[#F1EDFF]'
                        ]}
                    >
                        <i class={`fa-solid ${l.icon}`} aria-hidden="true" /> {l.label}
                    </a>
                ))
            }
        </nav>

        <button
            id="theme-toggle"
            type="button"
            role="switch"
            aria-label="Toggle dark mode"
            class="relative w-14 h-7 rounded-full border border-orange-200 dark:border-night-raised bg-orange-100/80 dark:bg-night-line transition-colors cursor-pointer shrink-0"
        >
            <span class="absolute inset-0 flex items-center justify-between px-2 text-[11px]" aria-hidden="true">
                <i class="fa-solid fa-sun text-amber-500"></i>
                <i class="fa-solid fa-moon text-brand-teal-soft"></i>
            </span>
            <span class="theme-knob absolute top-0.5 left-0.5 w-6 h-6 rounded-full bg-white dark:bg-night-card shadow-md transition-transform duration-300 dark:translate-x-7"></span>
        </button>
    </div>
</header>

<!-- Mobile bottom navigation -->
<nav
    class="md:hidden fixed bottom-0 left-0 right-0 z-50 bg-white/95 dark:bg-night-card/95 border-t border-orange-200/50 dark:border-night-line shadow-lg flex items-center justify-around h-16 backdrop-blur-md pb-[env(safe-area-inset-bottom)]"
    aria-label="Primary mobile"
>
    {
        links.map(l => (
            <a
                href={l.href}
                aria-current={isActive(l.href) ? 'page' : undefined}
                class:list={[
                    'flex flex-col items-center gap-1 justify-center w-14 h-full text-[9px] font-black transition-colors',
                    isActive(l.href)
                        ? 'text-brand-teal'
                        : 'text-slate-500 dark:text-[#B1A9DE]'
                ]}
            >
                <i class={`fa-solid ${l.icon} text-base`} aria-hidden="true" />
                <span>{l.label.replace('Body ', '').replace(' A–Z', '')}</span>
            </a>
        ))
    }
</nav>

<script>
    const toggle = document.getElementById('theme-toggle');
    const sync = () => toggle?.setAttribute('aria-checked', String(document.documentElement.classList.contains('dark')));
    sync();
    toggle?.addEventListener('click', () => {
        const dark = document.documentElement.classList.toggle('dark');
        sync();
        try {
            localStorage.setItem('kidsdisease-theme', dark ? 'dark' : 'light');
        } catch {
            /* storage unavailable */
        }
    });
</script>
