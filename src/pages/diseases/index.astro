---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import UrgencyBadge from '../../components/UrgencyBadge.astro';
import { diseases, diseaseUrl, illustrationUrl, getSystem } from '../../lib/db';

// Group alphabetically for an A–Z directory
const sorted = [...diseases].sort((a, b) => a.name.localeCompare(b.name));
const groups = new Map<string, typeof sorted>();
for (const d of sorted) {
    const letter = d.name[0]!.toUpperCase();
    if (!groups.has(letter)) groups.set(letter, []);
    groups.get(letter)!.push(d);
}
const letters = [...groups.keys()];
---

<Base
    title={`Childhood Diseases List A–Z (${diseases.length} Conditions) | Kids Disease`}
    description={`Complete A–Z list of ${diseases.length} childhood illnesses with symptoms, treatment, prevention and when to see a doctor — from asthma and croup to rare genetic conditions.`}
>
    <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Diseases A–Z' }]} />

    <div class="max-w-7xl mx-auto px-4 md:px-8 py-8 space-y-8">
        <header class="text-center space-y-2">
            <h1 class="text-2xl md:text-4xl font-black text-slate-800 dark:text-[#F1EDFF] tracking-tight">
                Childhood Diseases A–Z
            </h1>
            <p class="text-xs md:text-sm text-slate-600 dark:text-[#B1A9DE] font-bold max-w-xl mx-auto">
                All {diseases.length} indexed pediatric conditions. Every profile covers staged
                symptoms, home care, prevention, and doctor thresholds.
            </p>
        </header>

        <!-- Letter quick-nav -->
        <nav aria-label="Alphabetical navigation" class="flex flex-wrap justify-center gap-1.5">
            {
                letters.map(l => (
                    <a
                        href={`#letter-${l}`}
                        class="w-8 h-8 flex items-center justify-center rounded-lg bg-white dark:bg-night-card border border-orange-100 dark:border-night-line text-xs font-black text-slate-700 dark:text-[#D8D2F5] hover:border-brand-teal hover:text-brand-teal transition-colors"
                    >
                        {l}
                    </a>
                ))
            }
        </nav>

        {
            letters.map(l => (
                <section id={`letter-${l}`} class="scroll-mt-24 space-y-3" aria-labelledby={`heading-${l}`}>
                    <h2
                        id={`heading-${l}`}
                        class="text-lg font-black text-brand-teal border-b-2 border-teal-100 dark:border-night-line pb-1 w-10"
                    >
                        {l}
                    </h2>
                    <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3 list-none">
                        {groups.get(l)!.map(d => (
                            <li>
                                <a
                                    href={diseaseUrl(d)}
                                    class="flex items-center gap-3 bg-white dark:bg-night-card rounded-2xl border border-orange-100 dark:border-night-line p-3.5 hover:border-brand-teal/40 hover:shadow-card-hover transition-all"
                                >
                                    <img
                                        src={illustrationUrl(d.imagePath)}
                                        alt=""
                                        width="36"
                                        height="36"
                                        loading="lazy"
                                        class="w-9 h-9 rounded-xl bg-orange-50 dark:bg-night-line p-1 object-contain shrink-0"
                                    />
                                    <span class="flex-1 min-w-0">
                                        <span class="block text-xs font-black text-slate-800 dark:text-[#F1EDFF] truncate">{d.name}</span>
                                        <span class="block text-[10px] font-bold text-slate-500 dark:text-[#8B84B8] truncate">
                                            {getSystem(d.body_system)?.name}
                                        </span>
                                    </span>
                                    <UrgencyBadge level={d.urgency_level} />
                                </a>
                            </li>
                        ))}
                    </ul>
                </section>
            ))
        }

        <Disclaimer />
    </div>
</Base>
