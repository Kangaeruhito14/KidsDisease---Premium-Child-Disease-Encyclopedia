---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import DiseaseCard from '../../components/DiseaseCard.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import {
    bodySystems,
    getCategoriesBySystem,
    getDiseasesByCategory,
    getDiseasesBySystem,
    illustrationUrl
} from '../../lib/db';

export function getStaticPaths() {
    return bodySystems.map(s => ({ params: { id: s.id }, props: { system: s } }));
}

const { system: s } = Astro.props;
const categories = getCategoriesBySystem(s.id);
const total = getDiseasesBySystem(s.id).length;
---

<Base
    title={`${s.name} Diseases in Children (${total} Conditions) | PediaCare`}
    description={`${s.name} in children: ${s.description} ${total} indexed conditions with symptoms, treatment and prevention.`}
>
    <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Body Systems', href: '/systems/' }, { name: s.name }]} />

    <div class="max-w-7xl mx-auto px-4 md:px-8 py-8 space-y-8">
        <header class="bg-white dark:bg-night-card rounded-3xl border border-orange-100 dark:border-night-line shadow-premium p-6 md:p-8 flex flex-col md:flex-row items-start gap-6 fade-in-up">
            <img
                src={illustrationUrl(s.imagePath)}
                alt=""
                width="80"
                height="80"
                class="w-20 h-20 object-contain animate-float"
            />
            <div class="space-y-2 flex-1">
                <h1 class="text-2xl md:text-3xl font-black text-slate-800 dark:text-[#F1EDFF] tracking-tight">{s.name}</h1>
                <p class="text-sm text-slate-600 dark:text-[#B1A9DE] font-medium leading-relaxed">{s.description}</p>
                <p class="text-[10px] font-black uppercase tracking-wider text-brand-teal">
                    {categories.length} subcategories • {total} reference files
                </p>
            </div>
        </header>

        {
            categories.map(cat => {
                const ds = getDiseasesByCategory(cat.id);
                return (
                    <section class="space-y-4" aria-labelledby={`cat-${cat.id}`}>
                        <h2
                            id={`cat-${cat.id}`}
                            class="text-sm md:text-base font-black text-slate-700 dark:text-[#D8D2F5] flex items-center gap-2"
                        >
                            <i class="fa-solid fa-folder-open text-brand-coral" aria-hidden="true" />
                            {cat.name}
                            <span class="text-[10px] font-black text-slate-500 dark:text-[#8B84B8] uppercase">({ds.length})</span>
                        </h2>
                        {ds.length > 0 ? (
                            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                                {ds.map(d => (
                                    <DiseaseCard disease={d} />
                                ))}
                            </div>
                        ) : (
                            <p class="text-xs text-slate-500 dark:text-[#8B84B8] font-bold">
                                No diseases indexed under this classification tier yet.
                            </p>
                        )}
                    </section>
                );
            })
        }

        <Disclaimer />
    </div>
</Base>
