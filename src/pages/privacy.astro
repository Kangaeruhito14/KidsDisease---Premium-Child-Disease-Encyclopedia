---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const updated = '2026-06-11';
---

<Base
    title="Privacy Policy | PediaCare"
    description="PediaCare's privacy policy: a static educational site with no accounts, no tracking cookies, and no collection of health data. Theme preference is stored locally on your device."
>
    <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Privacy Policy' }]} />

    <article class="max-w-3xl mx-auto px-4 md:px-8 py-8 space-y-6">
        <header class="space-y-1">
            <h1 class="text-2xl md:text-4xl font-black text-slate-800 dark:text-[#F1EDFF] tracking-tight">Privacy Policy</h1>
            <p class="text-[10px] font-black uppercase tracking-wider text-slate-500 dark:text-[#8B84B8]">Last updated: {updated}</p>
        </header>

        <div class="bg-white dark:bg-night-card rounded-3xl border border-orange-100 dark:border-night-line shadow-premium p-6 md:p-8 space-y-5 text-sm text-slate-700 dark:text-[#D8D2F5] font-medium leading-relaxed">
            <section class="space-y-2">
                <h2 class="text-base font-black text-slate-800 dark:text-[#F1EDFF]">What we collect: essentially nothing</h2>
                <p class="text-xs md:text-sm">
                    PediaCare is a static website. It has no user accounts, no forms that submit
                    data to us, no advertising trackers, and no analytics cookies. We never see
                    what you search for or which conditions you read about — searches and the
                    triage checker run entirely inside your browser and are not transmitted.
                </p>
            </section>
            <section class="space-y-2">
                <h2 class="text-base font-black text-slate-800 dark:text-[#F1EDFF]">Health information</h2>
                <p class="text-xs md:text-sm">
                    We do not collect, store, or process any health information about you or your
                    child. Triage answers exist only in your browser tab and disappear when you
                    leave the page.
                </p>
            </section>
            <section class="space-y-2">
                <h2 class="text-base font-black text-slate-800 dark:text-[#F1EDFF]">Local storage</h2>
                <p class="text-xs md:text-sm">
                    One preference — your light/dark theme choice — is stored in your browser's
                    local storage under <code>pediacare-theme</code>. It never leaves your device.
                </p>
            </section>
            <section class="space-y-2">
                <h2 class="text-base font-black text-slate-800 dark:text-[#F1EDFF]">Third-party resources</h2>
                <p class="text-xs md:text-sm">
                    Pages load fonts from Google Fonts and icons from Cloudflare's cdnjs. Your
                    browser contacts those servers to fetch the files, which exposes your IP
                    address to them under their own privacy policies. No other third parties are
                    involved.
                </p>
            </section>
            <section class="space-y-2">
                <h2 class="text-base font-black text-slate-800 dark:text-[#F1EDFF]">Children's privacy</h2>
                <p class="text-xs md:text-sm">
                    The site is written for parents and caregivers. Because we collect no personal
                    data at all, no data about children is collected either.
                </p>
            </section>
            <section class="space-y-2">
                <h2 class="text-base font-black text-slate-800 dark:text-[#F1EDFF]">Changes</h2>
                <p class="text-xs md:text-sm">
                    If hosting or features ever change what is collected, this page will be
                    updated first, with the date above revised.
                </p>
            </section>
        </div>
    </article>
</Base>
